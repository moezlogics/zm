{
  "name": "my-store-backend",
  "version": "0.0.1",
  "description": "E-Commerce Backend Application.",
  "author": "Store Admin",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "backend"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "db:inspect": "node inspect-db.cjs",
    "db:reset": "node full-db-reset.cjs",
    "db:reset:force": "node full-db-reset.cjs --force",
    "db:reset:seed": "node full-db-reset.cjs --force --seed",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "pg": "^8.11.5",
    "recharts": "^2.12.7",
    "imurmurhash": "^0.1.4",
    "@ariakit/core": "^0.4.19",
    "@ariakit/react-core": "^0.4.25",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cache-redis": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/event-bus-redis": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/workflow-engine-redis": "2.13.6",
    "@rokmohar/medusa-plugin-meilisearch": "^1.3.8",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@variablevic/google-analytics-medusa": "^0.1.1",
    "glob": "^13.0.6",
    "meilisearch": "^0.57.0",
    "nodemailer": "^8.0.5",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@medusajs/admin-sdk": "$@medusajs/admin-sdk",
    "@medusajs/cache-redis": "$@medusajs/cache-redis",
    "@medusajs/cli": "$@medusajs/cli",
    "@medusajs/event-bus-redis": "$@medusajs/event-bus-redis",
    "@medusajs/framework": "$@medusajs/framework",
    "@medusajs/medusa": "$@medusajs/medusa",
    "@medusajs/workflow-engine-redis": "$@medusajs/workflow-engine-redis"
  },
  "packageManager": "npm@11.11.0"
}
